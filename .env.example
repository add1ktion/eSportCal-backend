# ==========================================
# ⚙️ GLOBAL CONFIGURATION
# ==========================================
# The port on which the Node.js backend runs
PORT=5001

# The URL of the React frontend (used for CORS policy)
CLIENT_URL=http://localhost:5173


# ==========================================
# 🐼 PANDASCORE API (Sprint 1 & 2)
# ==========================================
# Secret key to fetch e-sport matches (Ask on Discord if needed)
PANDASCORE_API_KEY=insert_pandascore_api_key_here


# ==========================================
# 🐘 POSTGRESQL DATABASE (Sprint 1 & 3)
# ==========================================
# Local database connection credentials
DB_USER=your_mac_or_postgres_username
DB_PASSWORD=your_password_if_any
DB_HOST=localhost
DB_PORT=5432
DB_NAME=esportcal_db


# =======================================
# 🔐 SECURITY & AUTHENTICATION (Sprint 3)
# =======================================
# Encryption key used to generate JSON Web Tokens (JWT)
# Use a long, random string (keep it identical for both team members)
JWT_SECRET=your_secure_random_string_for_local_development
JWT_EXPIRES_IN=7d


# ========================================
# 📧 Professional Email SMTP Configuration
# ========================================
EMAIL_HOST=your_smtp_host
EMAIL_PORT=465
EMAIL_USER=your_pro_email@esportcal.com
EMAIL_PASS=your_email_password
EMAIL_TO=your_admin_inbox@esportcal.com

# ========================================
# 🔑 OAUTH PROVIDERS CONFIGURATION
# ========================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5001/api/auth/google/callback

TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret
TWITCH_REDIRECT_URI=http://localhost:5001/api/auth/twitch/callback